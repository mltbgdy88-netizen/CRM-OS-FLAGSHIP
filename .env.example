# Sprint-01 / Sprint-02 local development defaults (no production secrets)

# Migration/admin connection (docker-compose postgres or local instance)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crmos

# DEV / LOCAL ONLY — crmos_app is created by 002_iam migration with password crmos_app.
# Production application DB roles must be provisioned by infra/DevOps, not by app migrations.
DATABASE_APP_URL=postgresql://crmos_app:crmos_app@localhost:5432/crmos

REDIS_URL=redis://localhost:6379
# Queue runtime: Redis + BullMQ (canon). RabbitMQ deferred to later sprints.
API_PORT=3001
WEB_PORT=3000
JWT_SECRET=change-me-local-only

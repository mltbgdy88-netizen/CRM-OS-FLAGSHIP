# Local development defaults (no production secrets)

# CRM-OS proof Postgres on port 5433 (127.0.0.1).
# localhost:5432 is often another Docker project and causes auth_failed during migrate/seed.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/crmos

# Application role (crmos_app) — created by 002_iam migration for dev/local/CI proof only.
# Production DB roles and secrets must be provisioned by infra/DevOps, not app migrations.
DATABASE_APP_URL=postgresql://crmos_app:crmos_app@127.0.0.1:5433/crmos

REDIS_URL=redis://localhost:6379
# Queue runtime: Redis + BullMQ (canon). RabbitMQ deferred to later sprints.
API_PORT=3001
WEB_PORT=3000
CORS_ORIGIN=http://localhost:3000
# CRM_OS_PROOF_SEED_CLEANUP=true  # optional; auto-enabled for 127.0.0.1:5433 proof DB

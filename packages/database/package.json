{
  "name": "@crm-os/database",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:rls": "node ./scripts/require-database-url.mjs && vitest run src/rls.test.ts src/rls-crm.test.ts src/rls-crm-360.test.ts src/rls-lead.test.ts src/rls-sales.test.ts src/rls-sales-opportunity.test.ts",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed/run.ts",
    "prisma:generate": "prisma generate",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "pg": "^8.13.1",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

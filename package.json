{
  "name": "crm-os",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "echo e2e-not-configured-yet",
    "db:migrate": "pnpm --filter @crm-os/database migrate",
    "db:seed": "pnpm --filter @crm-os/database seed",
    "db:test:rls": "pnpm --filter @crm-os/database test:rls",
    "generate:module": "echo generator-runtime-not-configured-yet",
    "validate:specs": "echo spec-validator-not-configured-yet",
    "openapi:validate": "echo openapi-validation-not-configured",
    "db:migrate:check": "pnpm sprint:02:verify",
    "ci:check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "sprint:01:verify": "pnpm run ci:check",
    "sprint:02:verify:core": "pnpm db:migrate && pnpm db:seed && pnpm db:test:rls && pnpm turbo build --filter=@crm-os/api... --filter=@crm-os/database... --filter=@crm-os/web... && pnpm --filter @crm-os/api test && pnpm --filter @crm-os/database test && pnpm --filter @crm-os/web test",
    "sprint:02:verify": "pnpm --filter @crm-os/database prisma:generate && pnpm sprint:02:verify:core && pnpm sprint:01:verify",
    "sprint:03:verify": "pnpm --filter @crm-os/database prisma:generate && pnpm sprint:02:verify:core && pnpm sprint:01:verify",
    "sprint:04:verify": "pnpm sprint:03:verify",
    "sprint:05:verify": "pnpm sprint:04:verify",
    "sprint:06:verify": "pnpm sprint:05:verify",
    "sprint:07:verify": "pnpm sprint:06:verify",
    "sprint:08:verify": "pnpm sprint:07:verify",
    "sprint:09:verify": "pnpm sprint:08:verify",
    "sprint:10:verify": "pnpm sprint:09:verify",
    "sprint:11:verify": "pnpm sprint:10:verify",
    "sprint:12:verify": "pnpm sprint:11:verify",
    "sprint:13:verify": "pnpm sprint:12:verify",
    "sprint:14:verify": "pnpm sprint:13:verify",
    "sprint:15:verify": "pnpm sprint:14:verify",
    "sprint:16:verify": "pnpm sprint:15:verify",
    "sprint:17:verify": "pnpm sprint:16:verify"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  }
}

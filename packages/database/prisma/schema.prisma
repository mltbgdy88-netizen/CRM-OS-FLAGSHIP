  productVariant   ProductVariant   @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "idx_stock_reservations_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_stock_reservations_tenant_deleted")
  @@index([orderId], map: "idx_stock_reservations_order_id")
  @@index([orderReservationId], map: "idx_stock_reservations_order_reservation_id")
  @@index([stockId], map: "idx_stock_reservations_stock_id")
  @@index([warehouseId], map: "idx_stock_reservations_warehouse_id")
  @@index([productVariantId], map: "idx_stock_reservations_product_variant_id")
  @@map("stock_reservations")
}

/// Tenant-owned product collection junction.
model ProductCollectionItem {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  collectionId String    @map("collection_id") @db.Uuid
  productId    String    @map("product_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy    String?   @map("created_by") @db.Uuid
  updatedAt    DateTime? @map("updated_at") @db.Timestamptz(6)
  updatedBy    String?   @map("updated_by") @db.Uuid
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy    String?   @map("deleted_by") @db.Uuid
  version      Int       @default(1)

  collection ProductCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product    Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([collectionId, productId], map: "uq_product_collection_items_collection_product")
  @@index([tenantId], map: "idx_product_collection_items_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_product_collection_items_tenant_deleted")
  @@index([collectionId], map: "idx_product_collection_items_collection_id")
  @@index([productId], map: "idx_product_collection_items_product_id")
  @@map("product_collection_items")
}

/// Global identity — not tenant-scoped.
model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique @db.VarChar(255)
  phone        String?   @db.VarChar(50)
  passwordHash String?   @map("password_hash")
  firstName    String    @map("first_name") @db.VarChar(100)
  lastName     String    @map("last_name") @db.VarChar(100)
  status       String    @default("active") @db.VarChar(30)
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  version      Int       @default(1)

  memberships  TenantMember[]
  auditLogs    AuditLog[]     @relation("AuditActor")
  sessions     Session[]
  devices      Device[]
  assignedLeads Lead[]        @relation("LeadAssignedUser")
  leadAssignments LeadAssignment[] @relation("LeadAssignmentUser")
  assignedOpportunities Opportunity[] @relation("OpportunityAssignedUser")
  assignedTasks Task[]          @relation("TaskAssignedUser")
  taskAssignees TaskAssignee[]  @relation("TaskAssigneeUser")
  taskComments  TaskComment[]   @relation("TaskCommentAuthor")
  notificationRecipients NotificationRecipient[] @relation("NotificationRecipientUser")
  notificationPreferences NotificationPreference[] @relation("NotificationPreferenceUser")

  @@map("users")
}

/// User-to-tenant membership — tenant-owned.
model TenantMember {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  status    String    @default("active") @db.VarChar(30)
  joinedAt  DateTime? @map("joined_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedAt DateTime? @map("updated_at") @db.Timestamptz(6)
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid
  version   Int       @default(1)

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
  memberRoles MemberRole[]

  @@unique([tenantId, userId])
  @@index([tenantId], map: "idx_tenant_members_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_tenant_members_tenant_deleted")
  @@map("tenant_members")
}

/// Tenant-owned role.
model Role {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  code      String    @db.VarChar(80)
  name      String    @db.VarChar(120)
  isSystem  Boolean   @default(false) @map("is_system")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedAt DateTime? @map("updated_at") @db.Timestamptz(6)
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid
  version   Int       @default(1)

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  rolePermissions RolePermission[]
  memberRoles     MemberRole[]

  @@unique([tenantId, code])
  @@index([tenantId], map: "idx_roles_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_roles_tenant_deleted")
  @@map("roles")
}

/// Global permission registry.
model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique @db.VarChar(150)
  module      String   @db.VarChar(80)
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@map("permissions")
}

/// Role-to-permission mapping — tenant-scoped via tenant_id.
model RolePermission {
  tenantId     String @map("tenant_id") @db.Uuid
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([tenantId], map: "idx_role_permissions_tenant_id")
  @@map("role_permissions")
}

/// Membership-to-role mapping — tenant-scoped via tenant_id.
model MemberRole {
  tenantId       String @map("tenant_id") @db.Uuid
  tenantMemberId String @map("tenant_member_id") @db.Uuid
  roleId         String @map("role_id") @db.Uuid

  tenantMember TenantMember @relation(fields: [tenantMemberId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([tenantMemberId, roleId])
  @@index([tenantId], map: "idx_member_roles_tenant_id")
  @@map("member_roles")
}

/// Tenant-owned audit trail.
model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  actorUserId  String?  @map("actor_user_id") @db.Uuid
  action       String   @db.VarChar(120)
  entityType   String   @map("entity_type") @db.VarChar(80)
  entityId     String?  @map("entity_id") @db.Uuid
  payload      Json?    @db.JsonB
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy    String?  @map("created_by") @db.Uuid
  updatedAt    DateTime? @map("updated_at") @db.Timestamptz(6)
  updatedBy    String?  @map("updated_by") @db.Uuid
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy    String?  @map("deleted_by") @db.Uuid
  version      Int      @default(1)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  actor  User?  @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([tenantId], map: "idx_audit_logs_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_audit_logs_tenant_deleted")
  @@index([tenantId, entityType, entityId], map: "idx_audit_logs_entity")
  @@map("audit_logs")
}

/// User-owned session with optional active tenant context.
model Session {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  activeTenantId   String?   @map("active_tenant_id") @db.Uuid
  refreshTokenHash String?   @map("refresh_token_hash")
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime? @map("updated_at") @db.Timestamptz(6)

  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeTenant Tenant? @relation(fields: [activeTenantId], references: [id])

  @@index([userId], map: "idx_sessions_user_id")
  @@map("sessions")
}

/// User-owned device with optional active tenant context.
model Device {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  activeTenantId    String?   @map("active_tenant_id") @db.Uuid
  deviceFingerprint String    @map("device_fingerprint") @db.VarChar(255)
  userAgent         String?   @map("user_agent")
  lastSeenAt        DateTime? @map("last_seen_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeTenant Tenant? @relation(fields: [activeTenantId], references: [id])

  @@index([userId], map: "idx_devices_user_id")
  @@map("devices")
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Global tenant / business account (workspace).
model Tenant {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String   @db.VarChar(255)
  slug             String   @unique @db.VarChar(100)
  status           String   @default("active") @db.VarChar(30)
  defaultCurrency  String   @default("TRY") @map("default_currency") @db.VarChar(3)
  timezone         String   @default("Europe/Istanbul") @db.VarChar(80)
  locale           String   @default("tr-TR") @db.VarChar(10)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime? @map("updated_at") @db.Timestamptz(6)
  version          Int      @default(1)

  members          TenantMember[]
  roles            Role[]
  auditLogs        AuditLog[]
  sessions         Session[]
  devices          Device[]
  customers        Customer[]
  leadSources      LeadSource[]
  leads            Lead[]
  pipelines        Pipeline[]

  @@map("tenants")
}

/// Tenant-owned customer aggregate root.
model Customer {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  displayName String    @map("display_name") @db.VarChar(255)
  email       String?   @db.VarChar(255)
  phone       String?   @db.VarChar(50)
  status      String    @default("active") @db.VarChar(30)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy   String?   @map("created_by") @db.Uuid
  updatedAt   DateTime? @map("updated_at") @db.Timestamptz(6)
  updatedBy   String?   @map("updated_by") @db.Uuid
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy   String?   @map("deleted_by") @db.Uuid
  version     Int       @default(1)

  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  contacts  CustomerContact[]
  addresses CustomerAddress[]
  tags      CustomerTag[]
  notes     CustomerNote[]
  files     CustomerFile[]
  timelineEvents CustomerTimelineEvent[]
  scores    CustomerScore[]
  riskScores CustomerRiskScore[]
  lifetimeValues CustomerLifetimeValue[]
  convertedLeads Lead[] @relation("LeadCustomer")
  opportunities Opportunity[]
  conversionLogs LeadConversionLog[]
  quotes        Quote[]
  orders        Order[]

  @@index([tenantId], map: "idx_customers_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_customers_tenant_deleted")
  @@map("customers")
}

/// Tenant-owned customer contact — read aggregation in customer detail.
model CustomerContact {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  customerId String    @map("customer_id") @db.Uuid
  firstName  String    @map("first_name") @db.VarChar(100)
  lastName   String    @map("last_name") @db.VarChar(100)
  email      String?   @db.VarChar(255)
  phone      String?   @db.VarChar(50)
  title      String?   @db.VarChar(120)
  isPrimary  Boolean   @default(false) @map("is_primary")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy  String?   @map("created_by") @db.Uuid
  updatedAt  DateTime? @map("updated_at") @db.Timestamptz(6)
  updatedBy  String?   @map("updated_by") @db.Uuid
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy  String?   @map("deleted_by") @db.Uuid
  version    Int       @default(1)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "idx_customer_contacts_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_customer_contacts_tenant_deleted")
  @@index([customerId], map: "idx_customer_contacts_customer_id")
  @@map("customer_contacts")
}

/// Tenant-owned customer address — read aggregation in customer detail.
model CustomerAddress {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  customerId  String    @map("customer_id") @db.Uuid
  label       String?   @db.VarChar(80)
  line1       String    @db.VarChar(255)
  line2       String?   @db.VarChar(255)
  city        String?   @db.VarChar(120)
  region      String?   @db.VarChar(120)
  postalCode  String?   @map("postal_code") @db.VarChar(30)
  countryCode String    @default("TR") @map("country_code") @db.VarChar(2)
  isPrimary   Boolean   @default(false) @map("is_primary")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy   String?   @map("created_by") @db.Uuid
  updatedAt   DateTime? @map("updated_at") @db.Timestamptz(6)
  updatedBy   String?   @map("updated_by") @db.Uuid
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy   String?   @map("deleted_by") @db.Uuid
  version     Int       @default(1)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "idx_customer_addresses_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_customer_addresses_tenant_deleted")
  @@index([customerId], map: "idx_customer_addresses_customer_id")
  @@map("customer_addresses")
}

/// Tenant-owned customer tag — read aggregation in customer detail.
model CustomerTag {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  customerId String    @map("customer_id") @db.Uuid
  name       String    @db.VarChar(80)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy  String?   @map("created_by") @db.Uuid
  updatedAt  DateTime? @map("updated_at") @db.Timestamptz(6)
  updatedBy  String?   @map("updated_by") @db.Uuid
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy  String?   @map("deleted_by") @db.Uuid
  version    Int       @default(1)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "idx_customer_tags_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_customer_tags_tenant_deleted")
  @@index([customerId], map: "idx_customer_tags_customer_id")
  @@map("customer_tags")
}

/// Tenant-owned customer note — read aggregation in customer detail.
model CustomerNote {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  customerId String    @map("customer_id") @db.Uuid
  title      String?   @db.VarChar(200)
  body       String
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy  String?   @map("created_by") @db.Uuid
  updatedAt  DateTime? @map("updated_at") @db.Timestamptz(6)
  updatedBy  String?   @map("updated_by") @db.Uuid
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy  String?   @map("deleted_by") @db.Uuid
  version    Int       @default(1)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "idx_customer_notes_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_customer_notes_tenant_deleted")
  @@index([customerId], map: "idx_customer_notes_customer_id")
  @@map("customer_notes")
}

/// Tenant-owned file metadata only — no upload/storage/CDN fields.
model CustomerFile {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  customerId String    @map("customer_id") @db.Uuid
  fileName   String    @map("file_name") @db.VarChar(255)
  mimeType   String?   @map("mime_type") @db.VarChar(120)
  byteSize   BigInt?   @map("byte_size")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy  String?   @map("created_by") @db.Uuid
  updatedAt  DateTime? @map("updated_at") @db.Timestamptz(6)
  updatedBy  String?   @map("updated_by") @db.Uuid
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy  String?   @map("deleted_by") @db.Uuid
  version    Int       @default(1)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "idx_customer_files_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_customer_files_tenant_deleted")
  @@index([customerId], map: "idx_customer_files_customer_id")
  @@map("customer_files")
}

/// Tenant-owned customer timeline event for Customer 360.
model CustomerTimelineEvent {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  customerId String    @map("customer_id") @db.Uuid
  eventType  String    @map("event_type") @db.VarChar(80)
  title      String    @db.VarChar(255)
  summary    String?
  occurredAt DateTime  @default(now()) @map("occurred_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy  String?   @map("created_by") @db.Uuid
  updatedAt  DateTime? @map("updated_at") @db.Timestamptz(6)
  updatedBy  String?   @map("updated_by") @db.Uuid
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy  String?   @map("deleted_by") @db.Uuid
  version    Int       @default(1)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "idx_customer_timeline_events_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_customer_timeline_events_tenant_deleted")
  @@index([customerId], map: "idx_customer_timeline_events_customer_id")
  @@index([tenantId, occurredAt], map: "idx_customer_timeline_events_occurred_at")
  @@map("customer_timeline_events")
}

/// Tenant-owned customer engagement/health score.
model CustomerScore {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  customerId String    @map("customer_id") @db.Uuid
  metricCode String    @map("metric_code") @db.VarChar(80)
  scoreValue Decimal   @map("score_value") @db.Decimal(12, 4)
  recordedAt DateTime  @default(now()) @map("recorded_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy  String?   @map("created_by") @db.Uuid
  updatedAt  DateTime? @map("updated_at") @db.Timestamptz(6)
  updatedBy  String?   @map("updated_by") @db.Uuid
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy  String?   @map("deleted_by") @db.Uuid
  version    Int       @default(1)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "idx_customer_scores_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_customer_scores_tenant_deleted")
  @@index([customerId], map: "idx_customer_scores_customer_id")
  @@map("customer_scores")
}

/// Tenant-owned customer risk assessment snapshot.
model CustomerRiskScore {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  customerId String    @map("customer_id") @db.Uuid
  riskLevel  String    @map("risk_level") @db.VarChar(40)
  riskScore  Decimal   @map("risk_score") @db.Decimal(12, 4)
  assessedAt DateTime  @default(now()) @map("assessed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy  String?   @map("created_by") @db.Uuid
  updatedAt  DateTime? @map("updated_at") @db.Timestamptz(6)
  updatedBy  String?   @map("updated_by") @db.Uuid
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy  String?   @map("deleted_by") @db.Uuid
  version    Int       @default(1)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "idx_customer_risk_scores_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_customer_risk_scores_tenant_deleted")
  @@index([customerId], map: "idx_customer_risk_scores_customer_id")
  @@map("customer_risk_scores")
}

/// Tenant-owned customer lifetime value snapshot.
model CustomerLifetimeValue {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  customerId   String    @map("customer_id") @db.Uuid
  currency     String    @default("TRY") @db.VarChar(3)
  ltvValue     Decimal   @map("ltv_value") @db.Decimal(14, 2)
  calculatedAt DateTime  @default(now()) @map("calculated_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy    String?   @map("created_by") @db.Uuid
  updatedAt    DateTime? @map("updated_at") @db.Timestamptz(6)
  updatedBy    String?   @map("updated_by") @db.Uuid
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy    String?   @map("deleted_by") @db.Uuid
  version      Int       @default(1)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "idx_customer_lifetime_values_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_customer_lifetime_values_tenant_deleted")
  @@index([customerId], map: "idx_customer_lifetime_values_customer_id")
  @@map("customer_lifetime_values")
}

/// Tenant-owned lead source lookup.
model LeadSource {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String    @db.VarChar(120)
  code      String    @db.VarChar(80)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedAt DateTime? @map("updated_at") @db.Timestamptz(6)
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid
  version   Int       @default(1)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  leads  Lead[]

  @@unique([tenantId, code], map: "uq_lead_sources_tenant_code")
  @@index([tenantId], map: "idx_lead_sources_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_lead_sources_tenant_deleted")
  @@map("lead_sources")
}

/// Tenant-owned lead aggregate root.
model Lead {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  fullName       String    @map("full_name") @db.VarChar(255)
  companyName    String    @map("company_name") @db.VarChar(255)
  email          String?   @db.VarChar(255)
  phone          String?   @db.VarChar(50)
  sourceId       String    @map("source_id") @db.Uuid
  status         String    @default("new") @db.VarChar(30)
  score          Int       @default(0)
  assignedUserId String?   @map("assigned_user_id") @db.Uuid
  customerId     String?   @map("customer_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy      String?   @map("created_by") @db.Uuid
  updatedAt      DateTime? @map("updated_at") @db.Timestamptz(6)
  updatedBy      String?   @map("updated_by") @db.Uuid
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy      String?   @map("deleted_by") @db.Uuid
  version        Int       @default(1)

  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  source       LeadSource  @relation(fields: [sourceId], references: [id])
  assignedUser User?       @relation("LeadAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  customer     Customer?   @relation("LeadCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  tags         LeadTag[]
  scores       LeadScore[]
  assignments  LeadAssignment[]
  activities   LeadActivity[]
  opportunities Opportunity[]
  conversionLogs LeadConversionLog[]

  @@index([tenantId], map: "idx_leads_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_leads_tenant_deleted")
  @@index([sourceId], map: "idx_leads_source_id")
  @@index([assignedUserId], map: "idx_leads_assigned_user_id")
  @@index([customerId], map: "idx_leads_customer_id")
  @@map("leads")
}

/// Tenant-owned lead tag.
model LeadTag {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  leadId    String    @map("lead_id") @db.Uuid
  name      String    @db.VarChar(80)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedAt DateTime? @map("updated_at") @db.Timestamptz(6)
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid
  version   Int       @default(1)

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "idx_lead_tags_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_lead_tags_tenant_deleted")
  @@index([leadId], map: "idx_lead_tags_lead_id")
  @@map("lead_tags")
}

/// Tenant-owned lead score history.
model LeadScore {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  leadId     String    @map("lead_id") @db.Uuid
  scoreValue Int       @map("score_value")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy  String?   @map("created_by") @db.Uuid
  updatedAt  DateTime? @map("updated_at") @db.Timestamptz(6)
  updatedBy  String?   @map("updated_by") @db.Uuid
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy  String?   @map("deleted_by") @db.Uuid
  version    Int       @default(1)

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "idx_lead_scores_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_lead_scores_tenant_deleted")
  @@index([leadId], map: "idx_lead_scores_lead_id")
  @@map("lead_scores")
}

/// Tenant-owned lead assignment history.
model LeadAssignment {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  leadId         String    @map("lead_id") @db.Uuid
  assignedUserId String?   @map("assigned_user_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy      String?   @map("created_by") @db.Uuid
  updatedAt      DateTime? @map("updated_at") @db.Timestamptz(6)
  updatedBy      String?   @map("updated_by") @db.Uuid
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy      String?   @map("deleted_by") @db.Uuid
  version        Int       @default(1)

  lead         Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedUser User? @relation("LeadAssignmentUser", fields: [assignedUserId], references: [id], onDelete: SetNull)

  @@index([tenantId], map: "idx_lead_assignments_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_lead_assignments_tenant_deleted")
  @@index([leadId], map: "idx_lead_assignments_lead_id")
  @@index([assignedUserId], map: "idx_lead_assignments_assigned_user_id")
  @@map("lead_assignments")
}

/// Tenant-owned lead activity feed row.
model LeadActivity {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  leadId       String    @map("lead_id") @db.Uuid
  activityType String    @map("activity_type") @db.VarChar(80)
  title        String    @db.VarChar(255)
  body         String?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy    String?   @map("created_by") @db.Uuid
  updatedAt    DateTime? @map("updated_at") @db.Timestamptz(6)
  updatedBy    String?   @map("updated_by") @db.Uuid
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy    String?   @map("deleted_by") @db.Uuid
  version      Int       @default(1)

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "idx_lead_activities_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_lead_activities_tenant_deleted")
  @@index([leadId], map: "idx_lead_activities_lead_id")
  @@map("lead_activities")
}

/// Tenant-owned sales pipeline definition.
model Pipeline {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String    @db.VarChar(120)
  code      String    @db.VarChar(80)
  isDefault Boolean   @default(false) @map("is_default")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedAt DateTime? @map("updated_at") @db.Timestamptz(6)
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid
  version   Int       @default(1)

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  stages        PipelineStage[]
  opportunities Opportunity[]

  @@unique([tenantId, code], map: "uq_pipelines_tenant_code")
  @@index([tenantId], map: "idx_pipelines_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_pipelines_tenant_deleted")
  @@map("pipelines")
}

/// Tenant-owned pipeline stage.
model PipelineStage {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  pipelineId String    @map("pipeline_id") @db.Uuid
  name       String    @db.VarChar(120)
  code       String    @db.VarChar(80)
  sortOrder  Int       @map("sort_order")
  color      String?   @db.VarChar(20)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
